{
  "name": "@cfxdevkit/automation",
  "version": "0.0.0",
  "private": false,
  "description": "Automation strategies (limit, dca, stop-loss, scheduled).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "API.md",
    "STRUCTURE.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@cfxdevkit/core": "workspace:^",
    "@cfxdevkit/executor": "workspace:^",
    "@cfxdevkit/protocol": "workspace:^",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.45.2",
    "viem": "^2.21.0"
  },
  "peerDependencies": {
    "mysql2": "*",
    "postgres": "*"
  },
  "peerDependenciesMeta": {
    "mysql2": {
      "optional": true
    },
    "postgres": {
      "optional": true
    }
  }
}
