{
  "name": "@cfxdevkit/automation",
  "version": "2.0.9",
  "private": false,
  "description": "Automation strategies (limit, dca, stop-loss, scheduled).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "API.md",
    "STRUCTURE.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm clean",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@cfxdevkit/cdk": "workspace:^",
    "@cfxdevkit/executor": "workspace:^",
    "@cfxdevkit/protocol": "workspace:^",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "viem": "^2.54.6"
  },
  "peerDependencies": {
    "mysql2": "*",
    "postgres": "*"
  },
  "peerDependenciesMeta": {
    "mysql2": {
      "optional": true
    },
    "postgres": {
      "optional": true
    }
  },
  "sideEffects": false
}
