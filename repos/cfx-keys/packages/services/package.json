{
  "name": "@cfxdevkit/services",
  "version": "0.0.0",
  "private": false,
  "description": "Pluggable backends: keystore, crypto, dex, tokens.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./keystore": {
      "types": "./dist/keystore/index.d.ts",
      "import": "./dist/keystore/index.js"
    },
    "./keystore-audit": {
      "types": "./dist/keystore/audit.d.ts",
      "import": "./dist/keystore/audit.js"
    },
    "./keystore-memory": {
      "types": "./dist/keystore/memory/index.d.ts",
      "import": "./dist/keystore/memory/index.js"
    },
    "./keystore-file": {
      "types": "./dist/keystore/file/index.d.ts",
      "import": "./dist/keystore/file/index.js"
    },
    "./keystore-ledger": {
      "types": "./dist/keystore/ledger/index.d.ts",
      "import": "./dist/keystore/ledger/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js"
    },
    "./embedded-wallet": {
      "types": "./dist/embedded-wallet/index.d.ts",
      "import": "./dist/embedded-wallet/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "API.md",
    "STRUCTURE.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@cfxdevkit/core": "workspace:^",
    "@ledgerhq/hw-app-eth": "^7.8.1",
    "@ledgerhq/hw-transport-node-hid": "^6.33.1",
    "cive": "^0.8.1",
    "@noble/ciphers": "^1.3.0",
    "@noble/hashes": "^2.2.0",
    "viem": "^2.21.0"
  }
}
