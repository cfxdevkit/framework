{
  "name": "@cfxdevkit/signer-session",
  "version": "2.1.8",
  "private": false,
  "description": "Headless signer session factory — create a ready Signer pair (eSpace + Core) from any backend without browser UI.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cfxdevkit/cdk": "workspace:^",
    "@cfxdevkit/services": "workspace:^",
    "@cfxdevkit/wallet": "workspace:^"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "sideEffects": false,
  "optionalDependencies": {
    "@noble/hashes": "^2.2.0",
    "@onekeyfe/hd-common-connect-sdk": "^1.1.26"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cfxdevkit/framework"
  }
}
