{
  "name": "@cfxdevkit/signer-session",
  "version": "2.1.0",
  "private": false,
  "description": "Headless signer session factory — create a ready Signer pair (eSpace + Core) from any backend without browser UI.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cfxdevkit/cdk": "workspace:^",
    "@cfxdevkit/services": "workspace:^",
    "@cfxdevkit/wallet": "workspace:^"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.9"
  },
  "sideEffects": false,
  "optionalDependencies": {
    "@noble/hashes": "^1.1.3",
    "@onekeyfe/hd-common-connect-sdk": "^1.1.26"
  }
}
