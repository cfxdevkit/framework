{
  "name": "@cfxdevkit/wallet",
  "version": "2.1.8",
  "private": false,
  "description": "Session keys, signers, batched writes, capability policies.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./batcher": {
      "types": "./dist/batcher/index.d.ts",
      "import": "./dist/batcher/index.js"
    },
    "./signers": {
      "types": "./dist/signers/index.d.ts",
      "import": "./dist/signers/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./hardware": {
      "types": "./dist/hardware/index.d.ts",
      "import": "./dist/hardware/index.js"
    },
    "./hardware/onekey": {
      "types": "./dist/hardware/onekey/index.d.ts",
      "import": "./dist/hardware/onekey/index.js"
    },
    "./hardware/ledger": {
      "types": "./dist/hardware/ledger/index.d.ts",
      "import": "./dist/hardware/ledger/index.js"
    },
    "./hardware/satochip": {
      "types": "./dist/hardware/satochip/index.d.ts",
      "import": "./dist/hardware/satochip/index.js"
    },
    "./init": {
      "types": "./dist/init/index.d.ts",
      "import": "./dist/init/index.js"
    },
    "./policies": {
      "types": "./dist/policies/index.d.ts",
      "import": "./dist/policies/index.js"
    },
    "./session-key": {
      "types": "./dist/session-key/index.d.ts",
      "import": "./dist/session-key/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "API.md",
    "STRUCTURE.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm clean",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@cfxdevkit/cdk": "workspace:^",
    "@cfxdevkit/executor": "workspace:^",
    "@cfxdevkit/services": "workspace:^",
    "@noble/hashes": "^2.2.0",
    "viem": "^2.54.6"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/cfxdevkit/framework"
  }
}
