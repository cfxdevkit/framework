{
  "name": "@cfxdevkit/devnode",
  "version": "2.1.9",
  "private": false,
  "description": "Local Conflux dev node lifecycle.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cfxdevkit-devnode": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "API.md",
    "STRUCTURE.md"
  ],
  "sideEffects": false,
  "scripts": {
    "prepublishOnly": "pnpm clean",
    "build": "vite build",
    "start": "node ./dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@cfxdevkit/cdk": "workspace:^",
    "@xcfx/node": "^0.8.0",
    "cive": "^0.8.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cfxdevkit/framework"
  }
}
