{
  "name": "@cfxdevkit/wallet-connect",
  "version": "2.0.5",
  "private": false,
  "description": "Browser wallet connectors and headless UI.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./siwe": {
      "types": "./dist/siwe/index.d.ts",
      "import": "./dist/siwe/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "API.md",
    "STRUCTURE.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm clean",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@wagmi/core": "3.5.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.15",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.100.9",
    "@wagmi/core": "3.5.0",
    "@cfxdevkit/wallet": "workspace:^",
    "react": "^19.2.5",
    "wagmi": "^3.6.9"
  },
  "dependencies": {
    "@cfxdevkit/cdk": "workspace:^",
    "viem": "^2.21.0"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/cfxdevkit/framework"
  }
}
