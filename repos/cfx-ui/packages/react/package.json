{
  "name": "@cfxdevkit/react",
  "version": "2.0.1",
  "private": false,
  "description": "React hooks over @cfxdevkit/cdk.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./account": {
      "types": "./dist/account.d.ts",
      "import": "./dist/account/index.js"
    },
    "./balance": {
      "types": "./dist/balance.d.ts",
      "import": "./dist/balance/index.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context/index.js"
    },
    "./contract": {
      "types": "./dist/contract.d.ts",
      "import": "./dist/contract/index.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events/index.js"
    },
    "./tx": {
      "types": "./dist/tx.d.ts",
      "import": "./dist/tx/index.js"
    },
    "./keystore": {
      "types": "./dist/keystore/index.d.ts",
      "import": "./dist/keystore/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "API.md",
    "STRUCTURE.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm clean",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.15",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@cfxdevkit/wallet": "workspace:^",
    "@tanstack/react-query": "^5.100.9",
    "react": "^19.2.5",
    "viem": "^2.21.0"
  },
  "dependencies": {
    "@cfxdevkit/cdk": "workspace:^"
  },
  "sideEffects": false
}
