{
  "name": "@cfxdevkit/defi-react",
  "version": "2.0.6",
  "private": false,
  "description": "Opinionated DeFi widgets (swap, portfolio, picker).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./swap": {
      "types": "./dist/swap/index.d.ts",
      "import": "./dist/swap/index.js"
    },
    "./balance": {
      "types": "./dist/balance/index.d.ts",
      "import": "./dist/balance/index.js"
    },
    "./token-picker": {
      "types": "./dist/token-picker/index.d.ts",
      "import": "./dist/token-picker/index.js"
    },
    "./tx-status": {
      "types": "./dist/tx-status/index.d.ts",
      "import": "./dist/tx-status/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js"
    },
    "./service": {
      "types": "./dist/service/index.d.ts",
      "import": "./dist/service/index.js"
    },
    "./pool": {
      "types": "./dist/pool/index.d.ts",
      "import": "./dist/pool/index.js"
    },
    "./lp": {
      "types": "./dist/lp/index.d.ts",
      "import": "./dist/lp/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "API.md",
    "STRUCTURE.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm clean",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.15",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@cfxdevkit/theme": "workspace:^",
    "@tanstack/react-query": "^5.100.9",
    "react": "^19.2.5",
    "viem": "^2.21.0"
  },
  "dependencies": {
    "@cfxdevkit/abis": "workspace:^",
    "@cfxdevkit/cdk": "workspace:^",
    "@cfxdevkit/react": "workspace:^",
    "@cfxdevkit/ui-core": "workspace:^"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/cfxdevkit/framework"
  }
}
