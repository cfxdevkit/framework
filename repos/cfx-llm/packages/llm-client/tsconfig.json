{
  "extends": "@cfxdevkit/tsconfig/lib.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "noEmit": false,
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": true,
    "strict": false,
    "noImplicitAny": false,
    "exactOptionalPropertyTypes": false,
    "useUnknownInCatchVariables": false
  },
  "include": ["src/**/*", "workers/**/*"],
  "exclude": ["dist", "node_modules", "**/*.test.ts"]
}