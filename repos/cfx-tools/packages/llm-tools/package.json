{
  "name": "@cfxdevkit/llm-tools",
  "version": "0.0.0",
  "private": false,
  "description": "Local LLM automation tools for repository upkeep, validation, and Lemonade/Pi workflows.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cfx-llm": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "workers",
    "README.md",
    "API.md",
    "STRUCTURE.md"
  ],
  "scripts": {
    "build": "vite build",
    "llm": "tsx src/bin.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src workers",
    "clean": "rm -rf dist .vitest coverage"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.72.0",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
