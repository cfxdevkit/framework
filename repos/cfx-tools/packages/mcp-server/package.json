{
  "name": "@cfxdevkit/mcp-server",
  "version": "0.0.0",
  "private": false,
  "description": "MCP server exposing devkit tools to AI agents.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "API.md",
    "STRUCTURE.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@cfxdevkit/compiler": "workspace:^",
    "@cfxdevkit/contracts": "workspace:^",
    "@cfxdevkit/core": "workspace:^",
    "@cfxdevkit/devnode": "workspace:^",
    "@cfxdevkit/services": "workspace:^",
    "@cfxdevkit/wallet": "workspace:^"
  }
}
