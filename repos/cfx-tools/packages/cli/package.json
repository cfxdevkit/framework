{
  "name": "@cfxdevkit/cli",
  "version": "2.0.10",
  "private": false,
  "description": "Conflux developer CLI: network status + HD key derivation.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cfx": "./dist/bin.js",
    "cdk": "./dist/cdk.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm clean",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "dependencies": {
    "@cfxdevkit/cdk": "workspace:*",
    "@cfxdevkit/codegen-contracts": "workspace:*",
    "@cfxdevkit/services": "workspace:*",
    "@cfxdevkit/signer-session": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/cfxdevkit/framework"
  }
}
