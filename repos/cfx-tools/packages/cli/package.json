{
  "name": "@cfxdevkit/cli",
  "version": "0.0.0",
  "private": false,
  "description": "Conflux developer CLI: network status + HD key derivation.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cfx": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "dependencies": {
    "@cfxdevkit/codegen-contracts": "workspace:*",
    "@cfxdevkit/core": "workspace:*"
  },
  "devDependencies": {
    "@cfxdevkit/tsconfig": "workspace:*",
    "@cfxdevkit/biome-config": "workspace:*",
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.10.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.6"
  }
}
