{
  "name": "cfxdevkit-vscode-extension",
  "publisher": "cfxdevkit",
  "displayName": "Conflux DevKit",
  "description": "VS Code integration for Conflux node lifecycle, keystore wallet management, and contract deployment.",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/extension.js",
  "files": [
    "dist",
    "media",
    "README.md",
    "API.md",
    "STRUCTURE.md"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cfxdevkit-sidebar",
          "title": "Conflux DevKit",
          "icon": "media/cfxdevkit.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "cfxdevkit.selectNetwork",
        "title": "Conflux: Select Network",
        "icon": "$(globe)"
      },
      {
        "command": "cfxdevkit.initializeSetup",
        "title": "Conflux: Initialize Keystore",
        "icon": "$(key)"
      },
      {
        "command": "cfxdevkit.addWallet",
        "title": "Conflux: Add Wallet",
        "icon": "$(add)"
      },
      {
        "command": "cfxdevkit.selectWallet",
        "title": "Conflux: Select Wallet",
        "icon": "$(check)"
      },
      {
        "command": "cfxdevkit.selectAccount",
        "title": "Conflux: Select Account",
        "icon": "$(check)"
      },
      {
        "command": "cfxdevkit.removeWallet",
        "title": "Conflux: Remove Wallet",
        "icon": "$(trash)"
      },
      {
        "command": "cfxdevkit.unlockKeystore",
        "title": "Conflux: Unlock Keystore",
        "icon": "$(unlock)"
      },
      {
        "command": "cfxdevkit.lockKeystore",
        "title": "Conflux: Lock Keystore",
        "icon": "$(lock)"
      },
      {
        "command": "cfxdevkit.rotateKeystorePassphrase",
        "title": "Conflux: Change Keystore Password",
        "icon": "$(key)"
      },
      {
        "command": "cfxdevkit.nodeStart",
        "title": "Conflux: Start Node",
        "icon": "$(play)"
      },
      {
        "command": "cfxdevkit.nodeStop",
        "title": "Conflux: Stop Node",
        "icon": "$(debug-stop)"
      },
      {
        "command": "cfxdevkit.nodeRestart",
        "title": "Conflux: Restart Node",
        "icon": "$(refresh)"
      },
      {
        "command": "cfxdevkit.nodeWipe",
        "title": "Conflux: Wipe Node Data",
        "icon": "$(trash)"
      },
      {
        "command": "cfxdevkit.nodeWipeRestart",
        "title": "Conflux: Wipe Data And Restart Node",
        "icon": "$(trash)"
      },
      {
        "command": "cfxdevkit.mineBlocks",
        "title": "Conflux: Mine Blocks",
        "icon": "$(flame)"
      },
      {
        "command": "cfxdevkit.mining.start",
        "title": "Conflux: Start Continuous Mining"
      },
      {
        "command": "cfxdevkit.mining.stop",
        "title": "Conflux: Stop Continuous Mining"
      },
      {
        "command": "cfxdevkit.viewAccounts",
        "title": "Conflux: View Accounts",
        "icon": "$(person)"
      },
      {
        "command": "cfxdevkit.deployContract",
        "title": "Conflux: Deploy Contract",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "cfxdevkit.importContract",
        "title": "Conflux: Import Contract",
        "icon": "$(cloud-download)"
      },
      {
        "command": "cfxdevkit.listContracts",
        "title": "Conflux: List Deployed Contracts",
        "icon": "$(file-code)"
      },
      {
        "command": "cfxdevkit.refreshAccounts",
        "title": "Conflux: Refresh Accounts",
        "icon": "$(refresh)"
      },
      {
        "command": "cfxdevkit.refreshContracts",
        "title": "Conflux: Refresh Contracts",
        "icon": "$(refresh)"
      },
      {
        "command": "cfxdevkit.copyAddress",
        "title": "Conflux: Copy Address",
        "icon": "$(copy)"
      },
      {
        "command": "cfxdevkit.copyContractAddress",
        "title": "Conflux: Copy Contract Address",
        "icon": "$(copy)"
      },
      {
        "command": "cfxdevkit.abiCallRead",
        "title": "Conflux: Call Read Function",
        "icon": "$(eye)"
      },
      {
        "command": "cfxdevkit.abiCallWrite",
        "title": "Conflux: Send Write Function",
        "icon": "$(edit)"
      }
    ],
    "views": {
      "cfxdevkit-sidebar": [
        {
          "id": "cfxdevkit.mainView",
          "name": "Conflux DevKit"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "cfxdevkit.mainView",
        "contents": "Add or unlock a wallet to manage the local node, accounts, and contracts.\n[Add Wallet](command:cfxdevkit.addWallet)\n[Unlock Wallet](command:cfxdevkit.unlockKeystore)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cfxdevkit.refreshAccounts",
          "when": "view == cfxdevkit.mainView",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "cfxdevkit.unlockKeystore",
          "when": "view == cfxdevkit.mainView && viewItem =~ /cfxWallet.*Locked/",
          "group": "inline@1"
        },
        {
          "command": "cfxdevkit.lockKeystore",
          "when": "view == cfxdevkit.mainView && viewItem == cfxWalletActiveReady",
          "group": "inline@1"
        },
        {
          "command": "cfxdevkit.rotateKeystorePassphrase",
          "when": "view == cfxdevkit.mainView && viewItem == cfxWalletActiveReady",
          "group": "inline@2"
        },
        {
          "command": "cfxdevkit.removeWallet",
          "when": "view == cfxdevkit.mainView && viewItem =~ /cfxWallet/",
          "group": "inline@3"
        },
        {
          "command": "cfxdevkit.selectAccount",
          "when": "view == cfxdevkit.mainView && viewItem == cfxAccountItem",
          "group": "inline@1"
        },
        {
          "command": "cfxdevkit.nodeStart",
          "when": "view == cfxdevkit.mainView && viewItem == cfxLocalNodeStopped",
          "group": "inline@1"
        },
        {
          "command": "cfxdevkit.nodeWipe",
          "when": "view == cfxdevkit.mainView && viewItem == cfxLocalNodeStopped",
          "group": "inline@2"
        },
        {
          "command": "cfxdevkit.nodeStop",
          "when": "view == cfxdevkit.mainView && viewItem == cfxLocalNodeRunning",
          "group": "inline@1"
        },
        {
          "command": "cfxdevkit.nodeRestart",
          "when": "view == cfxdevkit.mainView && viewItem == cfxLocalNodeRunning",
          "group": "inline@2"
        },
        {
          "command": "cfxdevkit.nodeWipe",
          "when": "view == cfxdevkit.mainView && viewItem == cfxLocalNodeRunning",
          "group": "inline@3"
        },
        {
          "command": "cfxdevkit.mineBlocks",
          "when": "view == cfxdevkit.mainView && viewItem == cfxLocalNodeRunning",
          "group": "inline@4"
        },
        {
          "command": "cfxdevkit.copyAddress",
          "when": "viewItem == cfxAddressItem",
          "group": "inline"
        },
        {
          "command": "cfxdevkit.copyContractAddress",
          "when": "viewItem == cfxContractItem",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Conflux DevKit",
      "properties": {
        "cfxdevkit.autoStartNode": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the local dev node when the extension activates and the selected network is local."
        },
        "cfxdevkit.keystorePath": {
          "type": "string",
          "default": ".cfxdevkit/keystore.json",
          "description": "Workspace-relative path to the encrypted keystore file."
        },
        "cfxdevkit.deploymentsPath": {
          "type": "string",
          "default": ".cfxdevkit/deployments.json",
          "description": "Workspace-relative path to the deployment registry used by the extension."
        },
        "cfxdevkit.nodeDataDir": {
          "type": "string",
          "default": ".cfxdevkit/devnode",
          "description": "Workspace-relative data directory for the local Conflux dev node."
        },
        "cfxdevkit.nodeAccounts": {
          "type": "number",
          "default": 10,
          "description": "Number of pre-funded accounts to expose in the local dev node."
        },
        "cfxdevkit.nodeLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose local dev node logging in the extension output channel."
        }
      }
    }
  },
  "scripts": {
    "prepublishOnly": "pnpm clean",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src",
    "smoke:workflows": "node scripts/smoke-extension-workflows.mjs",
    "smoke:deploy": "node scripts/smoke-extension-workflows.mjs --deploy",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cfxdevkit/client": "workspace:^",
    "@cfxdevkit/compiler": "workspace:^",
    "@cfxdevkit/contracts": "workspace:^",
    "@cfxdevkit/cdk": "workspace:^",
    "@cfxdevkit/devnode-server": "workspace:^",
    "@cfxdevkit/services": "workspace:^",
    "@cfxdevkit/wallet": "workspace:^"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^6.0.3"
  },
  "sideEffects": false
}
