{
  "name": "cfxdevkit-vscode-extension",
  "publisher": "cfxdevkit",
  "displayName": "Conflux DevKit",
  "description": "VS Code integration for Conflux node lifecycle, keystore wallet management, and contract deployment.",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/extension.js",
  "files": [
    "dist",
    "media",
    "README.md",
    "API.md",
    "STRUCTURE.md"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cfxdevkit-sidebar",
          "title": "Conflux DevKit",
          "icon": "media/cfxdevkit.svg"
        }
      ]
    },
    "commands": [
      { "command": "cfxdevkit.selectNetwork", "title": "Conflux: Select Network", "icon": "$(globe)" },
      { "command": "cfxdevkit.selectKeystoreBackend", "title": "Conflux: Select Keystore Type", "icon": "$(key)" },
      { "command": "cfxdevkit.selectKeystoreFile", "title": "Conflux: Select Keystore File", "icon": "$(folder)" },
      { "command": "cfxdevkit.serverStart", "title": "Conflux: Start DevKit Runtime", "icon": "$(debug-start)" },
      { "command": "cfxdevkit.serverStop", "title": "Conflux: Stop Node", "icon": "$(debug-stop)" },
      { "command": "cfxdevkit.initializeSetup", "title": "Conflux: Initialize Keystore", "icon": "$(key)" },
      { "command": "cfxdevkit.addWallet", "title": "Conflux: Add Wallet", "icon": "$(add)" },
      { "command": "cfxdevkit.selectWallet", "title": "Conflux: Select Wallet", "icon": "$(check)" },
      { "command": "cfxdevkit.removeWallet", "title": "Conflux: Remove Wallet", "icon": "$(trash)" },
      { "command": "cfxdevkit.unlockKeystore", "title": "Conflux: Unlock Keystore", "icon": "$(unlock)" },
      { "command": "cfxdevkit.lockKeystore", "title": "Conflux: Lock Keystore", "icon": "$(lock)" },
      { "command": "cfxdevkit.rotateKeystorePassphrase", "title": "Conflux: Change Keystore Password", "icon": "$(key)" },
      { "command": "cfxdevkit.nodeStart", "title": "Conflux: Start Node", "icon": "$(play)" },
      { "command": "cfxdevkit.nodeStop", "title": "Conflux: Stop Node", "icon": "$(debug-stop)" },
      { "command": "cfxdevkit.nodeRestart", "title": "Conflux: Restart Node", "icon": "$(refresh)" },
      { "command": "cfxdevkit.nodeWipe", "title": "Conflux: Wipe Node Data" },
      { "command": "cfxdevkit.nodeWipeRestart", "title": "Conflux: Wipe Data And Restart Node" },
      { "command": "cfxdevkit.shutdown", "title": "Conflux: Shut Down Stack", "icon": "$(debug-stop)" },
      { "command": "cfxdevkit.mineBlocks", "title": "Conflux: Mine Blocks" },
      { "command": "cfxdevkit.viewAccounts", "title": "Conflux: View Accounts", "icon": "$(person)" },
      { "command": "cfxdevkit.deployContract", "title": "Conflux: Deploy Contract", "icon": "$(cloud-upload)" },
      { "command": "cfxdevkit.importContract", "title": "Conflux: Import Contract", "icon": "$(cloud-download)" },
      { "command": "cfxdevkit.listContracts", "title": "Conflux: List Deployed Contracts", "icon": "$(file-code)" },
      { "command": "cfxdevkit.refreshAccounts", "title": "Conflux: Refresh Accounts", "icon": "$(refresh)" },
      { "command": "cfxdevkit.refreshContracts", "title": "Conflux: Refresh Contracts", "icon": "$(refresh)" },
      { "command": "cfxdevkit.copyAddress", "title": "Conflux: Copy Address", "icon": "$(copy)" },
      { "command": "cfxdevkit.copyContractAddress", "title": "Conflux: Copy Contract Address", "icon": "$(copy)" },
      { "command": "cfxdevkit.abiCallRead", "title": "Conflux: Call Read Function", "icon": "$(eye)" },
      { "command": "cfxdevkit.abiCallWrite", "title": "Conflux: Send Write Function", "icon": "$(edit)" }
    ],
    "views": {
      "cfxdevkit-sidebar": [
        { "id": "cfxdevkit.networkView", "name": "Network" },
        { "id": "cfxdevkit.nodeView", "name": "Node" },
        { "id": "cfxdevkit.accountsView", "name": "Wallets" },
        { "id": "cfxdevkit.contractsView", "name": "Contracts" }
      ]
    },
    "viewsWelcome": [
      {
        "view": "cfxdevkit.networkView",
        "contents": "Select the active Conflux network.\n[Select Network](command:cfxdevkit.selectNetwork)"
      },
      {
        "view": "cfxdevkit.nodeView",
        "contents": "Start the local dev node when working against the local chain.\n[Start Node](command:cfxdevkit.nodeStart)"
      },
      {
        "view": "cfxdevkit.accountsView",
        "contents": "Choose a keystore type, then add or select a wallet before node and contract operations.\n[Select Keystore Type](command:cfxdevkit.selectKeystoreBackend)\n[Add Wallet](command:cfxdevkit.addWallet)\n[Unlock Keystore](command:cfxdevkit.unlockKeystore)"
      },
      {
        "view": "cfxdevkit.contractsView",
        "contents": "Deploy or import a contract from the active network and space.\n[Deploy Contract](command:cfxdevkit.deployContract)\n[Import Contract](command:cfxdevkit.importContract)"
      }
    ],
    "menus": {
      "view/title": [
        { "command": "cfxdevkit.selectNetwork", "when": "view == cfxdevkit.networkView", "group": "navigation@1" },
        { "command": "cfxdevkit.selectKeystoreBackend", "when": "view == cfxdevkit.accountsView", "group": "navigation@1" },
        { "command": "cfxdevkit.nodeStart", "when": "view == cfxdevkit.nodeView", "group": "navigation@1" },
        { "command": "cfxdevkit.refreshAccounts", "when": "view == cfxdevkit.accountsView", "group": "navigation@2" },
        { "command": "cfxdevkit.deployContract", "when": "view == cfxdevkit.contractsView", "group": "navigation@1" },
        { "command": "cfxdevkit.importContract", "when": "view == cfxdevkit.contractsView", "group": "navigation@2" },
        { "command": "cfxdevkit.refreshContracts", "when": "view == cfxdevkit.contractsView", "group": "navigation@3" }
      ],
      "view/item/context": [
        { "command": "cfxdevkit.unlockKeystore", "when": "view == cfxdevkit.accountsView && viewItem == cfxWalletRootActiveLocked", "group": "inline@1" },
        { "command": "cfxdevkit.lockKeystore", "when": "view == cfxdevkit.accountsView && viewItem == cfxWalletRootActiveReady", "group": "inline@1" },
        { "command": "cfxdevkit.removeWallet", "when": "view == cfxdevkit.accountsView && viewItem =~ /cfxWalletRoot/", "group": "inline@2" },
        { "command": "cfxdevkit.copyAddress", "when": "viewItem == cfxAddressItem", "group": "inline" },
        { "command": "cfxdevkit.copyContractAddress", "when": "viewItem == cfxContractItem", "group": "inline" }
      ]
    },
    "configuration": {
      "title": "Conflux DevKit",
      "properties": {
        "cfxdevkit.autoStartNode": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the local dev node when the extension activates and the selected network is local."
        },
        "cfxdevkit.keystorePath": {
          "type": "string",
          "default": ".cfxdevkit/keystore.json",
          "description": "Workspace-relative path to the encrypted keystore file."
        },
        "cfxdevkit.satoshiBridgeUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8397",
          "description": "Local Satoshi/Satochip bridge URL used by the Satoshi keystore backend."
        },
        "cfxdevkit.deploymentsPath": {
          "type": "string",
          "default": ".cfxdevkit/deployments.json",
          "description": "Workspace-relative path to the deployment registry used by the extension."
        },
        "cfxdevkit.nodeDataDir": {
          "type": "string",
          "default": ".cfxdevkit/devnode",
          "description": "Workspace-relative data directory for the local Conflux dev node."
        },
        "cfxdevkit.nodeAccounts": {
          "type": "number",
          "default": 10,
          "description": "Number of pre-funded accounts to expose in the local dev node."
        },
        "cfxdevkit.nodeLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose local dev node logging in the extension output channel."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cfxdevkit/compiler": "workspace:^",
    "@cfxdevkit/contracts": "workspace:^",
    "@cfxdevkit/core": "workspace:^",
    "@cfxdevkit/devnode": "workspace:^",
    "@cfxdevkit/services": "workspace:^",
    "@cfxdevkit/wallet": "workspace:^"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.0"
  }
}