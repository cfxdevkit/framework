{
  "name": "@cfxdevkit/devnode-core",
  "version": "2.1.8",
  "private": false,
  "description": "Lightweight Hono control plane for Conflux devnode — node control, compilation, and mining. No keystore or wallet deps.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cfxdevkit/cdk": "workspace:^",
    "@cfxdevkit/compiler": "workspace:^",
    "@cfxdevkit/devnode": "workspace:^",
    "@hono/node-server": "^2.0.8",
    "hono": "^4.12.28",
    "viem": "^2.54.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/cfxdevkit/framework"
  }
}
