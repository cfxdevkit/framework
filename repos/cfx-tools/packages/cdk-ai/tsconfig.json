{
  "extends": "@cfxdevkit/tsconfig/lib.json",
  "compilerOptions": {
    "rootDir": "../..",
    "outDir": "dist",
    "declaration": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": true,
    "strict": false,
    "noImplicitAny": false,
    "exactOptionalPropertyTypes": false,
    "useUnknownInCatchVariables": false,
    "rootDirs": [".", "../../infra/llm-agents", "../../infra/pi-agent"],
    "paths": {
      "@cfxdevkit/llm-agents": ["../../infra/llm-agents/src/index.ts"],
      "@cfxdevkit/pi-agent": ["../../infra/pi-agent/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "**/*.test.ts", "**/*.test.tsx"]
}