{
  "name": "@cfxdevkit/devnode-server",
  "version": "2.0.9",
  "private": false,
  "description": "Shared Hono control plane for the local Conflux dev node.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cfxdevkit-devnode-server": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "API.md",
    "STRUCTURE.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm clean",
    "build": "vite build",
    "start": "node ./dist/cli.js serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "dependencies": {
    "@cfxdevkit/cdk": "workspace:^",
    "@cfxdevkit/compiler": "workspace:^",
    "@cfxdevkit/contracts": "workspace:^",
    "@cfxdevkit/devnode": "workspace:^",
    "@cfxdevkit/devnode-core": "workspace:^",
    "@cfxdevkit/keystore-server": "workspace:^",
    "@cfxdevkit/services": "workspace:^",
    "@cfxdevkit/wallet": "workspace:^",
    "@hono/node-server": "^2.0.8",
    "hono": "^4.12.28",
    "viem": "^2.54.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/cfxdevkit/framework"
  }
}
