{
  "name": "@cfxdevkit/docs-site",
  "version": "0.0.9",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3100 --turbopack",
    "sync:packages": "pnpm --filter @cfxdevkit/docs-pipeline run docs -- sync packages",
    "sync:architecture": "pnpm --filter @cfxdevkit/docs-pipeline run docs -- sync architecture",
    "sync:coverage": "pnpm --filter @cfxdevkit/docs-pipeline run docs -- sync coverage",
    "sync:wiki": "pnpm --filter @cfxdevkit/docs-pipeline run docs -- sync wiki",
    "sync:all": "pnpm --filter @cfxdevkit/docs-pipeline run docs -- sync all",
    "validate:wiki": "pnpm --filter @cfxdevkit/docs-pipeline run docs -- validate wiki",
    "validate:wiki-fix": "pnpm --filter @cfxdevkit/docs-pipeline run docs -- validate wiki-fix",
    "validate:packages": "pnpm --filter @cfxdevkit/docs-pipeline run docs -- validate content",
    "update:wiki": "pnpm --filter @cfxdevkit/docs-pipeline run docs -- wiki",
    "prebuild": "pnpm --filter @cfxdevkit/docs-pipeline run docs -- sync all && pnpm --filter @cfxdevkit/docs-pipeline run docs -- validate content",
    "build": "next build",
    "start": "next start --port 3100",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "mermaid": "^11.16.0",
    "next": "^16.2.10",
    "nextra": "^4.2.17",
    "nextra-theme-docs": "^4.2.17",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript/typescript6": "^6.0.2",
    "typescript": "^7.0.2"
  },
  "sideEffects": false
}
