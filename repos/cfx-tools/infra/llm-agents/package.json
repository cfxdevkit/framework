{
  "name": "@cfxdevkit/llm-agents",
  "version": "2.0.0",
  "private": false,
  "description": "Typed LLM workflow agents for Conflux DevKit repository automation.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "llm-agents": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "workers",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm clean",
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src workers",
    "clean": "rm -rf dist .vitest coverage",
    "llm-agents": "tsx src/bin.ts",
    "agent-smoke": "tsx src/bin.ts smoke",
    "agent-config": "tsx src/bin.ts config",
    "agent-status": "tsx src/bin.ts status",
    "agent-check": "tsx src/bin.ts check",
    "agent-merge": "tsx src/bin.ts merge",
    "agent-endpoints": "tsx src/bin.ts endpoints",
    "agent-modes": "tsx src/bin.ts modes",
    "agent-reviews": "tsx src/bin.ts exploratory all",
    "agent-validation": "tsx src/bin.ts exploratory validation",
    "deterministic": "tsx src/bin.ts deterministic",
    "exploratory": "tsx src/bin.ts exploratory"
  },
  "dependencies": {
    "@cfxdevkit/cdk-repo-check": "workspace:*",
    "@cfxdevkit/docs-pipeline": "workspace:*",
    "tsx": "^4.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/testing": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "sideEffects": false
}
