{
  "name": "@cfxdevkit/tooling-cli",
  "version": "0.0.5",
  "private": true,
  "description": "Repository maintenance CLI — validation, precommit, status, actions, review.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "repo": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm clean",
    "build": "vite build",
    "tooling": "tsx src/bin.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "dependencies": {
    "@cfxdevkit/cdk-repo-check": "workspace:*",
    "@cfxdevkit/docs-pipeline": "workspace:*",
    "@cfxdevkit/workspace-utils": "workspace:*",
    "@inquirer/prompts": "^8.4.3",
    "clipanion": "^4.0.0-rc.4"
  },
  "peerDependencies": {
    "@cfxdevkit/llm-agents": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/testing": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "sideEffects": false
}
