{
  "name": "@cfxdevkit/codegen-contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Extracts ABI + bytecode from Hardhat artifacts and renders TypeScript modules consumed by @cfxdevkit/contracts.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cfxdevkit-extract-contracts": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "devDependencies": {
    "@cfxdevkit/tsconfig": "workspace:*",
    "@cfxdevkit/biome-config": "workspace:*",
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.0.0"
  }
}
