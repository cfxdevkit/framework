{
  "name": "@cfxdevkit/contracts",
  "version": "2.0.11",
  "private": false,
  "description": "Standard contract bindings (ERC-20/721/1155, multicall3) and a thin read/write/deploy surface for @cfxdevkit/cdk.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./abis": {
      "types": "./dist/abis/index.d.ts",
      "import": "./dist/abis/index.js"
    },
    "./read": {
      "types": "./dist/read/index.d.ts",
      "import": "./dist/read/index.js"
    },
    "./write": {
      "types": "./dist/write/index.d.ts",
      "import": "./dist/write/index.js"
    },
    "./deploy": {
      "types": "./dist/deploy/index.d.ts",
      "import": "./dist/deploy/index.js"
    },
    "./erc20": {
      "types": "./dist/erc20/index.d.ts",
      "import": "./dist/erc20/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge/index.d.ts",
      "import": "./dist/bridge/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "API.md",
    "STRUCTURE.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm clean",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .vitest coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@cfxdevkit/abis": "workspace:^",
    "@cfxdevkit/cdk": "workspace:^",
    "viem": "^2.54.6"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/cfxdevkit/framework"
  }
}
