{
  "name": "@cfxdevkit/example-showcase-public",
  "version": "0.0.4",
  "private": true,
  "description": "Conflux framework public showcase — deployable Next.js app targeting testnet.",
  "scripts": {
    "dev": "next dev --webpack --port 3010",
    "build": "pnpm exec next build --webpack",
    "start": "next start --port 3010",
    "typecheck": "tsc --noEmit",
    "lint": "biome check app",
    "clean": "rm -rf .next",
    "dev:https": "next dev --webpack --experimental-https --port 3010"
  },
  "dependencies": {
    "@cfxdevkit/cdk": "workspace:*",
    "@cfxdevkit/defi-react": "workspace:*",
    "@cfxdevkit/example-showcase-ui": "workspace:*",
    "@cfxdevkit/protocol": "workspace:*",
    "@cfxdevkit/react": "workspace:*",
    "@cfxdevkit/theme": "workspace:*",
    "@cfxdevkit/ui-core": "workspace:^",
    "@cfxdevkit/wallet": "workspace:*",
    "@cfxdevkit/wallet-connect": "workspace:*",
    "@ledgerhq/hw-app-eth": "^7.8.8",
    "@ledgerhq/hw-transport-webhid": "^6.36.0",
    "@onekeyfe/hd-common-connect-sdk": "^1.1.28",
    "@tanstack/react-query": "^5.101.2",
    "next": "^16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "^2.54.6",
    "wagmi": "^3.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript/typescript6": "^6.0.2",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2"
  }
