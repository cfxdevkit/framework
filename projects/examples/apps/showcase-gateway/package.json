{
  "name": "@cfxdevkit/example-showcase-gateway",
  "version": "0.0.0",
  "private": true,
  "description": "Single dev entry point and reverse proxy for the cfxdevkit showcase apps.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:gateway": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .vite"
  },
  "dependencies": {
    "@cfxdevkit/example-showcase-ui": "workspace:*",
    "react": "^19.2.6",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
