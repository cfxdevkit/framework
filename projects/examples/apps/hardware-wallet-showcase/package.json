{
  "name": "@cfxdevkit/example-hardware-wallet-showcase",
  "version": "0.0.0",
  "private": true,
  "description": "Browser keystore management showcase covering memory, file, and hardware wallets.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:gateway": "VITE_BASE_PATH=/keystores/ VITE_DEV_PORT=5184 vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .vite"
  },
  "dependencies": {
    "@cfxdevkit/core": "workspace:*",
    "@cfxdevkit/example-showcase-ui": "workspace:*",
    "@cfxdevkit/services": "workspace:*",
    "@cfxdevkit/wallet": "workspace:*",
    "@ledgerhq/hw-app-eth": "^7.8.1",
    "@ledgerhq/hw-transport-webhid": "^6.35.1",
    "buffer": "^6.0.3",
    "react": "^18.3.0",
    "react-dom": "^19.2.6",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
