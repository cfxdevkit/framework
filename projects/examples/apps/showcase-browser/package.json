{
  "name": "@cfxdevkit/example-showcase-browser",
  "version": "0.0.0",
  "private": true,
  "description": "Browser showcase: external user wallets (Fluent · MetaMask · injected EIP-1193) on Conflux Core + eSpace, no backend.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:gateway": "VITE_BASE_PATH=/browser/ VITE_DEV_PORT=5183 vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .vite"
  },
  "dependencies": {
    "@cfxdevkit/contracts": "workspace:*",
    "@cfxdevkit/example-showcase-ui": "workspace:*",
    "@cfxdevkit/core": "workspace:*",
    "@cfxdevkit/services": "workspace:*",
    "@cfxdevkit/wallet": "workspace:*",
    "@cfxjs/use-wallet-react": "^0.0.9",
    "@tanstack/react-query": "^5.62.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "viem": "^2.21.0",
    "wagmi": "^2.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
