{
  "name": "@cfxdevkit/example-showcase-backend",
  "version": "0.0.0",
  "private": true,
  "description": "Backend companion for the showcase app: SIWE auth + session-key delegation.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:gateway": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run",
    "clean": "rm -rf dist .vitest coverage"
  },
  "dependencies": {
    "@cfxdevkit/compiler": "workspace:*",
    "@cfxdevkit/core": "workspace:*",
    "@cfxdevkit/devnode": "workspace:*",
    "@cfxdevkit/services": "workspace:*",
    "@cfxdevkit/wallet": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "siwe": "^2.3.2",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^25.6.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
