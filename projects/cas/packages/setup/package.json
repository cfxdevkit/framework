{
  "name": "@cfxdevkit/cas-setup",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "description": "Interactive CLI wizard for setting up a CAS instance.",
  "bin": {
    "cas-setup": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run",
    "clean": "rm -rf dist .vitest coverage"
  },
  "dependencies": {
    "@cfxdevkit/cdk": "workspace:*",
    "@cfxdevkit/contracts": "workspace:*",
    "@cfxdevkit/protocol": "workspace:*",
    "@inquirer/prompts": "^8.4.3",
    "commander": "^15.0.0",
    "viem": "^2.54.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "tsup": "^8.5.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
