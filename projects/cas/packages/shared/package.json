{
  "name": "@cfxdevkit/cas-shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared CAS API and domain contracts.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./admin": {
      "types": "./dist/admin.d.ts",
      "import": "./dist/admin.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.js"
    },
    "./jobs": {
      "types": "./dist/jobs.d.ts",
      "import": "./dist/jobs.js"
    },
    "./pools": {
      "types": "./dist/pools.d.ts",
      "import": "./dist/pools.js"
    },
    "./sse": {
      "types": "./dist/sse.d.ts",
      "import": "./dist/sse.js"
    },
    "./system": {
      "types": "./dist/system.d.ts",
      "import": "./dist/system.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run",
    "clean": "rm -rf dist .vitest coverage"
  },
  "dependencies": {
    "@cfxdevkit/automation": "workspace:*",
    "@cfxdevkit/cdk": "workspace:*",
    "@cfxdevkit/protocol": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.7"
  }
}
