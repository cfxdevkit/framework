# ── Server ────────────────────────────────────────────────────────────────────

# TCP port the backend listens on (default: 3011)
PORT=3011

# Bind address (default: 0.0.0.0; use 127.0.0.1 to restrict to localhost only)
CAS_BACKEND_HOST=0.0.0.0

# ── SQLite ─────────────────────────────────────────────────────────────────────

# Path to the SQLite database file (relative or absolute).
# Default: projects/cas/.data/cas-dev.sqlite (resolved relative to the backend package)
# CAS_SQLITE_PATH=../../.data/cas-dev.sqlite

# ── Auth ───────────────────────────────────────────────────────────────────────

# Secret key used to sign SIWE session tokens — change this in any shared environment
CAS_AUTH_SECRET=cas-local-dev-secret

# Session token lifetime in milliseconds (default: 86400000 = 24 h)
# CAS_SESSION_TTL_MS=86400000

# SIWE nonce expiry in milliseconds (default: 300000 = 5 min)
# CAS_NONCE_TTL_MS=300000

# ── CORS ───────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins (leave unset = allow all, fine for local dev)
# CAS_CORS_ORIGINS=http://localhost:3010,https://your-frontend.example.com

# ── Network ────────────────────────────────────────────────────────────────────

# Conflux eSpace network: "testnet" or "mainnet" (default: mainnet)
NETWORK=testnet

# Conflux eSpace JSON-RPC endpoint.
# Defaults to the public endpoint for the selected NETWORK if omitted.
CONFLUX_ESPACE_RPC=https://evmtestnet.confluxrpc.com

# ── Contracts ──────────────────────────────────────────────────────────────────
# Contract addresses default to the canonical deployed values for the chosen NETWORK.
# Override only if using a local or custom deployment.

# AutomationManager — on-chain job registry
# Testnet: 0x33e5E5B262e5d8eBC443E1c6c9F14215b020554d
# Mainnet: 0x9D5B131e5bA37A238cd1C485E2D9d7c2A68E1d0F
AUTOMATION_MANAGER_ADDRESS=0x33e5E5B262e5d8eBC443E1c6c9F14215b020554d

# SwappiPriceAdapter — on-chain price oracle
# Testnet: 0x88C48e0E8F76493Bb926131a2BE779cc17ecBEdF
# Mainnet: 0xD2Cc2a7Eb4A5792cE6383CcD0f789C1A9c48ECf9
PRICE_ADAPTER_ADDRESS=0x88C48e0E8F76493Bb926131a2BE779cc17ecBEdF

# PermitHandler — ERC-20 permit gateway
# Testnet: 0x4240882f2d9d70cdb9fbcc859cdd4d3e59f5d137
# Mainnet: 0x0D566aC9Dd1e20Fc63990bEEf6e8abBA876c896B
PERMIT_HANDLER_ADDRESS=0x4240882f2d9d70cdb9fbcc859cdd4d3e59f5d137

# Swappi Router — DEX router used for on-chain swaps (same address on both networks)
SWAPPI_ROUTER_ADDRESS=0x62B0873055Bf896Dd869e172119871ac24aeA305

# ── Admin ──────────────────────────────────────────────────────────────────────

# Comma-separated list of lowercase hex addresses allowed to call /admin/* routes.
# Leave empty to disable admin access (all /admin/* routes will return 403).
# ADMIN_ADDRESSES=0xYourAdminAddress1,0xYourAdminAddress2

# ── Pools ──────────────────────────────────────────────────────────────────────

# How long to cache pool/token lists from the price source (default: 1800000 = 30 min)
# POOLS_CACHE_TTL_MS=1800000

# Price feed source: "swappi" or "gecko_terminal" (default: swappi)
# PRICE_SOURCE=swappi

# ── Keeper ─────────────────────────────────────────────────────────────────────
# The keeper worker is embedded in the backend process and disabled by default.
# When enabled, it polls for executable jobs and submits on-chain transactions.
#
# PREREQUISITE: The signer address MUST be registered on the AutomationManager
# contract via setKeeper(signerAddress, true) by the contract owner BEFORE enabling
# the keeper. Without registration every execution transaction will revert with
# "Unauthorized". See the README keeper section for the registration command.

# Enable the embedded keeper worker (default: false)
KEEPER_ENABLED=false

# WARNING: Never commit a real private key. Use a dedicated testnet-only account.
# SIGNER_PRIVATE_KEY=0xYOUR_SIGNER_PRIVATE_KEY_HERE

# How often the keeper polls for executable jobs in milliseconds (default: 15000)
# KEEPER_INTERVAL_MS=15000

# Maximum number of jobs the keeper executes concurrently (default: 1)
# KEEPER_CONCURRENCY=1

# Maximum gas price in Gwei the keeper will pay (default: 500)
# MAX_GAS_PRICE_GWEI=500
