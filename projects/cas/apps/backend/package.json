{
  "name": "@cfxdevkit/cas-backend",
  "version": "0.0.4",
  "private": true,
  "description": "CAS backend for local SQLite-backed development.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run",
    "clean": "rm -rf dist .vitest coverage"
  },
  "dependencies": {
    "@cfxdevkit/automation": "workspace:*",
    "@cfxdevkit/cas-shared": "workspace:*",
    "@cfxdevkit/cdk": "workspace:*",
    "@cfxdevkit/protocol": "workspace:*",
    "@cfxdevkit/services": "workspace:*",
    "@cfxdevkit/wallet-connect": "workspace:*",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "viem": "^2.54.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cfxdevkit/biome-config": "workspace:*",
    "@cfxdevkit/tsconfig": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "@typescript/typescript6": "^6.0.2",
    "supertest": "^7.1.4",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
