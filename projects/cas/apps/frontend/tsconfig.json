{
  "extends": "@cfxdevkit/tsconfig/app-web.json",
  "compilerOptions": {
    "allowJs": false,
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ES2023", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "types": ["node", "react", "react-dom"],
    "paths": {
      "@cfxdevkit/ui": ["../../../../repos/cfx-ui/packages/ui/src/index.ts"],
      "@cfxdevkit/ui-core": ["../../../../repos/cfx-ui/packages/ui-core/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
