{
  "name": "Conflux DevKit Root",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "node",
  "containerUser": "node",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "runArgs": [
    "--privileged",
    "--network",
    "pasta:--map-gw",
    "-p",
    "8443:443",
    "--add-host=host.containers.internal:169.254.1.2",
    "--cap-add=NET_BIND_SERVICE",
    "--device=/dev/bus/usb"
  ],
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "mounts": [
    "source=${localWorkspaceFolder}/.devcontainer/.docker.sock,target=/var/run/docker.sock,type=bind,consistency=cached",
    "source=/dev/bus/usb,target=/dev/bus/usb,type=bind",
    "source=cfxdevkit-pnpm-store,target=/home/node/.local/share/pnpm/store,type=volume",
    "source=cfxdevkit-moon-cache,target=/home/node/.cache/moon,type=volume",
    "source=cfxdevkit-gitnexus,target=/home/node/.local/share/gitnexus,type=volume",
    "source=cfxdevkit-headroom-cache,target=/home/node/.cache/headroom,type=volume"
  ],
  "containerEnv": {
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0",
    "PNPM_HOME": "/home/node/.local/share/pnpm",
    "PNPM_STORE_PATH": "/home/node/.local/share/pnpm/store",
    "LEMONADE_URL": "http://localhost:28787/v1/",
    "LEMONADE_BASE_URL": "http://localhost:28787/v1/",
    "OPENAI_BASE_URL": "http://localhost:28787/v1",
    "ANTHROPIC_BASE_URL": "http://localhost:28787",
    "HEADROOM_UPSTREAM": "http://host.containers.internal:13305/",
    "HEADROOM_PROXY_PORT": "28787",
    "HEADROOM_CODE_AWARE_ENABLED": "false",
    "EXA_API_KEY": "${localEnv:EXA_API_KEY}",
    "PERPLEXITY_API_KEY": "${localEnv:PERPLEXITY_API_KEY}",
    "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}"
  },
  "forwardPorts": [8545, 8546, 12536, 12537, 3000, 4173, 5173, 7748, 8787, 28787],
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  },
  "portsAttributes": {
    "8545": {
      "label": "Conflux eSpace RPC"
    },
    "8546": {
      "label": "Conflux eSpace WebSocket"
    },
    "12536": {
      "label": "Conflux Core WebSocket"
    },
    "12537": {
      "label": "Conflux Core RPC"
    },
    "3000": {
      "label": "App server"
    },
    "4173": {
      "label": "Vite preview"
    },
    "5173": {
      "label": "Vite dev server"
    },
    "7748": {
      "label": "Legacy DevKit backend"
    },
    "8787": {
      "label": "Worker/backend dev server"
    },
    "28787": {
      "label": "Headroom compression proxy",
      "onAutoForward": "notify"
    }
  },
  "initializeCommand": ".devcontainer/scripts/detect-docker-socket.sh",
  "postCreateCommand": "bash .devcontainer/scripts/post-create.sh",
  "postStartCommand": ".devcontainer/scripts/post-start.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "biomejs.biome",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "github.vscode-github-actions",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        "ts.tsdk.path": "node_modules/typescript/lib",
        "terminal.integrated.defaultProfile.linux": "bash",
        "remote.autoForwardPorts": false,
        "remote.autoForwardPortsFallback": 0,
        "remote.autoForwardPortsSource": "process",
        "remote.restoreForwardedPorts": false,
        "remote.otherPortsAttributes": {
          "onAutoForward": "ignore"
        },
        "dev.containers.autoForwardPorts": false,
        "dev.containers.autoForwardPortsFallback": 0
      }
    }
  }
}
