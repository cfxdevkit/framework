{
  "name": "@cfxdevkit/root",
  "version": "0.0.0",
  "private": true,
  "description": "Conflux DevKit monorepo — framework, platform, domains, projects.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "moon run :build",
    "test": "moon run :test",
    "lint": "moon run :lint",
    "typecheck": "moon run :typecheck",
    "check": "moon run :check",
    "clean": "moon run :clean",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "gitnexus:ensure": ".devcontainer/scripts/ensure-gitnexus.sh",
    "gitnexus:list": "pnpm run gitnexus:ensure && pnpm exec gitnexus list",
    "gitnexus:status": "pnpm run gitnexus:ensure && pnpm exec gitnexus status && pnpm exec gitnexus list",
    "llm:all": "node scripts/llm-agents.mjs all",
    "llm": "node scripts/lemonade-cli.mjs",
    "llm:actions": "node scripts/lemonade-cli.mjs actions",
    "llm:action": "node scripts/lemonade-cli.mjs run",
    "llm:ask": "node scripts/lemonade-cli.mjs ask",
    "llm:config": "node scripts/lemonade-cli.mjs config",
    "llm:commit": "node scripts/lemonade-cli.mjs commit",
    "llm:corpus": "node scripts/llm-agents.mjs corpus",
    "llm:datasets": "node scripts/llm-agents.mjs datasets",
    "llm:docs": "node scripts/llm-agents.mjs docs",
    "llm:eval": "node scripts/llm-agents.mjs eval",
    "llm:models": "node scripts/lemonade-cli.mjs models",
    "llm:review": "node scripts/llm-agents.mjs review",
    "llm:serve-check": "node scripts/llm-agents.mjs serve-check",
    "security:audit": "pnpm audit --prod --audit-level moderate",
    "security:secrets": "node scripts/check-secret-leaks.mjs",
    "security:check": "pnpm run security:audit && pnpm run security:secrets",
    "devnode": "pnpm --filter @cfxdevkit/devnode build && pnpm --filter @cfxdevkit/devnode start"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@changesets/cli": "^2.31.0",
    "@moonrepo/cli": "^2.2.3",
    "gitnexus": "^1.6.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.15.0",
      "tmp": "^0.2.4",
      "uuid": "^14.0.0"
    },
    "onlyBuiltDependencies": [
      "@ladybugdb/core",
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
