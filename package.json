{
  "name": "@cfxdevkit/framework",
  "version": "0.0.0",
  "private": true,
  "description": "Conflux DevKit monorepo — framework, platform, domains, projects.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "moon run :build",
    "test": "moon run :test --concurrency 1",
    "test:cover": "pnpm -r --if-present test:coverage",
    "lint": "moon run :lint",
    "typecheck": "moon run :typecheck",
    "check": "moon run :check",
    "clean": "moon run :clean",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check:hotspots": "moon run arch-check:check-hotspots",
    "check:secrets": "moon run arch-check:check-secrets",
    "check:ci": "moon run arch-check:check-ci",
    "check:docs": "moon run arch-check:check-docs",
    "check:corpus": "moon run arch-check:check-corpus",
    "check:eval": "moon run arch-check:check-eval",
    "arch:check": "moon run arch-check:arch-check",
    "gitnexus:ensure": ".devcontainer/scripts/ensure-gitnexus.sh",
    "gitnexus:list": "pnpm run gitnexus:ensure && pnpm exec gitnexus list",
    "gitnexus:status": "pnpm run gitnexus:ensure && pnpm exec gitnexus status && pnpm exec gitnexus list",
    "llm:all": "pnpm --filter @cfxdevkit/llm-tools llm -- all",
    "llm": "pnpm --filter @cfxdevkit/llm-tools llm --",
    "llm:actions": "pnpm --filter @cfxdevkit/llm-tools llm -- actions",
    "llm:action": "pnpm --filter @cfxdevkit/llm-tools llm -- action",
    "llm:ask": "pnpm --filter @cfxdevkit/llm-tools llm -- ask",
    "llm:changeset": "pnpm --filter @cfxdevkit/llm-tools llm -- changeset",
    "llm:ci-cd": "pnpm --filter @cfxdevkit/llm-tools llm -- ci-cd",
    "llm:config": "pnpm --filter @cfxdevkit/llm-tools llm -- config",
    "llm:commit": "pnpm --filter @cfxdevkit/llm-tools llm -- commit",
    "llm:docs-pipeline": "pnpm --filter @cfxdevkit/llm-tools llm -- docs-pipeline",
    "llm:docs-upkeep": "pnpm --filter @cfxdevkit/llm-tools llm -- docs-upkeep",
    "llm:health": "pnpm --filter @cfxdevkit/llm-tools llm -- health",
    "llm:models": "pnpm --filter @cfxdevkit/llm-tools llm -- models",
    "llm:release": "pnpm --filter @cfxdevkit/llm-tools llm -- release",
    "llm:review": "pnpm --filter @cfxdevkit/llm-tools llm -- review",
    "llm:test-audit": "pnpm --filter @cfxdevkit/llm-tools llm -- test-audit",
    "llm:test-upkeep": "pnpm --filter @cfxdevkit/llm-tools llm -- test-upkeep",
    "llm:validation": "pnpm --filter @cfxdevkit/llm-tools llm -- validation",
    "security:audit": "pnpm audit --prod --audit-level moderate",
    "security:check": "pnpm run security:audit && pnpm run check:secrets",
    "showcase": "pnpm --parallel --filter @cfxdevkit/example-showcase-backend --filter @cfxdevkit/example-showcase --filter @cfxdevkit/example-showcase-stack --filter @cfxdevkit/example-showcase-browser --filter @cfxdevkit/example-hardware-wallet-showcase --filter @cfxdevkit/example-showcase-gateway dev:gateway",
    "devnode": "pnpm --filter @cfxdevkit/devnode build && pnpm --filter @cfxdevkit/devnode start"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@changesets/cli": "^2.31.0",
    "@moonrepo/cli": "^2.2.4",
    "gitnexus": "^1.6.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.15.0",
      "ip-address": "^10.1.1",
      "postcss": "^8.5.10",
      "tmp": "^0.2.4",
      "uuid": "^14.0.0",
      "viem": "^2.21.0",
      "wagmi": "^3.6.9",
      "zod": "4.3.4"
    },
    "onlyBuiltDependencies": [
      "@ladybugdb/core",
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
