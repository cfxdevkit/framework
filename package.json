{
  "name": "@cfxdevkit/framework",
  "version": "2.0.0",
  "private": true,
  "description": "Conflux DevKit monorepo — framework, platform, domains, projects.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "moon run :build --concurrency 3",
    "changeset": "npx changeset",
    "changeset:status": "npx changeset status",
    "changeset:version": "npx changeset version",
    "changeset:check": "node scripts/changeset-check.mjs",
    "cdk:refresh": ".devcontainer/scripts/install-cdk.sh",
    "test": "moon run :test --concurrency 1",
    "test:cover": "pnpm -r --if-present test:coverage",
    "lint": "moon run :lint --concurrency 4",
    "typecheck": "moon run :typecheck --concurrency 4",
    "check": "moon run :check --concurrency 2",
    "clean": "moon run :clean",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check:hotspots": "moon run arch-check-check-hotspots",
    "check:kebab-groups": "moon run arch-check-check-kebab-groups",
    "check:unit-configs": "moon run arch-check-check-unit-configs",
    "check:secrets": "moon run arch-check-check-secrets",
    "check:ci": "moon run arch-check-check-ci",
    "check:docs": "moon run arch-check-check-docs",
    "gen:api": "moon run arch-check-generate-api",
    "gen:readme": "moon run arch-check-generate-readme",
    "gen:structure": "moon run arch-check-generate-structure",
    "gen:unit-configs": "moon run arch-check-generate-unit-configs",
    "check:corpus": "moon run arch-check-check-corpus",
    "check:eval": "moon run arch-check-check-eval",
    "arch:check": "moon run arch-check-arch-check",
    "gitnexus:ensure": ".devcontainer/scripts/ensure-gitnexus.sh",
    "gitnexus:analyze": "pnpm run gitnexus:ensure && pnpm exec gitnexus analyze",
    "gitnexus:list": "pnpm run gitnexus:ensure && pnpm exec gitnexus list",
    "gitnexus:status": "pnpm run gitnexus:ensure && pnpm exec gitnexus status && pnpm exec gitnexus list",
    "docs": "moon run docs-validate",
    "docs:sync": "moon run docs-sync all",
    "docs:enrich:all": "moon run docs-enrich all",
    "docs:enrich:api": "moon run docs-enrich api",
    "docs:enrich:readme": "moon run docs-enrich readme",
    "docs:enrich:packages": "moon run docs-enrich packages",
    "docs:enrich:structure": "moon run docs-enrich structure",
    "docs:enrich:content": "moon run docs-enrich content",
    "docs:probe:api": "moon run docs-probe api",
    "docs:review": "moon run docs-review",
    "docs:wiki": "moon run docs-wiki",
    "docs:validate-wiki": "moon run docs-validate wiki",
    "docs:validate-wiki-fix": "moon run docs-validate wiki --fix",
    "docs:validate-packages": "moon run docs-validate packages",
    "sync:packages": "pnpm run tooling -- docs sync packages",
    "sync:architecture": "pnpm run tooling -- docs sync architecture",
    "sync:coverage": "pnpm run tooling -- docs sync coverage",
    "sync:wiki": "pnpm run tooling -- docs sync wiki",
    "tooling": "pnpm --filter @cfxdevkit/tooling-cli tooling --",
    "repo": "pnpm --filter @cfxdevkit/tooling-cli tooling repo",
    "repo:merge": "moon run tooling-cli:repo-merge",
    "repo:build": "moon run tooling-cli:repo-build",
    "repo:check": "moon run tooling-cli:repo-check",
    "repo:generate": "moon run tooling-cli:repo-generate",
    "repo:arch-check": "moon run tooling-cli:repo-arch-check",
    "repo:review": "moon run tooling-cli:repo-review",
    "repo:precommit": "moon run tooling-cli:repo-precommit",
    "repo:commit": "moon run tooling-cli:repo-commit",
    "agent": "moon run tooling-cli:agent-chat",
    "agent:config": "moon run tooling-cli:agent-config",
    "agent:status": "moon run tooling-cli:agent-status",
    "agent:modes": "moon run tooling-cli:agent-modes",
    "agent:providers": "moon run tooling-cli:agent-deterministic models",
    "llm": "moon run tooling-cli:agent-chat",
    "llm:all": "moon run tooling-cli:agent-exploratory all",
    "llm:actions": "moon run tooling-cli:agent-exploratory actions",
    "llm:action": "moon run tooling-cli:agent-exploratory action",
    "llm:ask": "moon run tooling-cli:agent-print --",
    "llm:changeset": "moon run tooling-cli:agent-exploratory changeset",
    "llm:changeset:generate": "moon run tooling-cli:agent-exploratory changeset --generate",
    "llm:ci-cd": "moon run tooling-cli:agent-exploratory ci-cd",
    "llm:config": "moon run tooling-cli:agent-config",
    "llm:commit": "moon run tooling-cli:repo-commit",
    "llm:docs-api": "moon run tooling-cli:agent-deterministic docs-api",
    "llm:readme-upkeep": "moon run tooling-cli:agent-deterministic readme-upkeep",
    "llm:package-pages": "moon run tooling-cli:agent-deterministic package-pages",
    "llm:structure-upkeep": "moon run tooling-cli:agent-deterministic structure-upkeep",
    "llm:wiki": "moon run docs-wiki",
    "llm:docs-pipeline": "moon run tooling-cli:agent-exploratory docs-pipeline",
    "llm:docs-upkeep": "moon run tooling-cli:agent-deterministic docs-upkeep",
    "llm:health": "moon run tooling-cli:agent-exploratory health",
    "llm:models": "moon run tooling-cli:agent-deterministic models",
    "llm:validate-models": "moon run tooling-cli:agent-deterministic validate-models",
    "llm:model": "moon run agent-config set default-model",
    "llm:release": "moon run tooling-cli:agent-exploratory release",
    "llm:review": "moon run tooling-cli:repo-review",
    "llm:test-audit": "moon run tooling-cli:agent-exploratory test-audit",
    "llm:test-upkeep": "moon run tooling-cli:agent-exploratory test-upkeep",
    "llm:validation": "moon run tooling-cli:agent-exploratory validation",
    "check:unused": "knip",
    "security:audit": "pnpm audit --prod --audit-level moderate",
    "security:check": "pnpm run security:audit && pnpm run check:secrets",
    "showcase": "moon run showcase",
    "showcase:public": "pnpm --filter @cfxdevkit/example-showcase-public dev",
    "showcase:stop": "moon run showcase-stop",
    "devnode": "moon run devnode-start",
    "setup:trust-local-ca": "bash scripts/setup-trust-local-ca.sh",
    "caddy:start": "caddy start --config infrastructure/local/Caddyfile --adapter caddyfile",
    "caddy:reload": "caddy reload --config infrastructure/local/Caddyfile --adapter caddyfile",
    "caddy:stop": "caddy stop"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.31.0",
    "@moonrepo/cli": "^2.3.4",
    "gitnexus": "^1.6.3",
    "knip": "^6.17.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "@onekeyfe/hd-transport>protobufjs": "^7.5.8",
      "axios": "^1.15.0",
      "@types/react": "^19.2.14",
      "esbuild": ">=0.25.0",
      "fast-uri": ">=3.1.2",
      "ip-address": "^10.1.1",
      "postcss": "^8.5.10",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "tmp": "^0.2.4",
      "uuid": "^14.0.0",
      "viem": "^2.21.0",
      "wagmi": "^3.6.9",
      "ws": ">=8.21.0",
      "zod": "4.3.4"
    },
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@ladybugdb/core",
      "better-sqlite3",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
