{
  "name": "@cfxdevkit/root",
  "version": "0.0.0",
  "private": true,
  "description": "Conflux DevKit monorepo — framework, platform, domains, projects.",
  "packageManager": "pnpm@10.6.0",
  "engines": {
    "node": "22.22.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "moon run :build",
    "test": "moon run :test",
    "lint": "moon run :lint",
    "typecheck": "moon run :typecheck",
    "check": "moon run :check",
    "clean": "moon run :clean",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "devnode": "pnpm --filter @cfxdevkit/devnode build && pnpm --filter @cfxdevkit/devnode start"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.27.0",
    "@moonrepo/cli": "^1.30.0",
    "gitnexus": "^1.6.3",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@ladybugdb/core",
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
