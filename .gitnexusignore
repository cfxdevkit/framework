# GitNexus ignore file — excludes paths from the knowledge graph index
# Syntax: same as .gitignore (glob patterns, one per line)

# ── Build outputs ─────────────────────────────────────────────────────────────
**/dist/
**/.next/
**/node_modules/
**/coverage/
**/.turbo/

# ── Artifacts & generated reports ────────────────────────────────────────────
artifacts/
**/*.json.bak

# ── OpenSpec planning files — not code, confuses grouping ────────────────────
openspec/

# ── Developer docs — useful prose but not source code ────────────────────────
docs/
infrastructure/

# ── Scratch/output files at repo root ────────────────────────────────────────
*.txt
*.log
*.md

# ── Archived packages — no longer active ─────────────────────────────────────
repos/cfx-tools/infra/archive/
repos/cfx-tools/packages/archive/

# ── Lock files ────────────────────────────────────────────────────────────────
**/pnpm-lock.yaml
**/package-lock.json
**/yarn.lock

# ── Config-only packages (no logic to document) ──────────────────────────────
repos/cfx-config/

# ── Pi agent prompts/skills/config — not public API ─────────────────────────
.pi/
.devcontainer/
