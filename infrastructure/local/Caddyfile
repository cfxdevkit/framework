# infrastructure/local/Caddyfile
#
# Local development reverse proxy.
# Mirrors infrastructure/vps/Caddyfile — same hostname structure, localhost upstreams.
#
# Prerequisites:
#   - *.dev.cfxdevkit.org A → 127.0.0.1 in Cloudflare (DNS only, no proxy)
#   - Certs generated by .devcontainer/scripts/setup-local.sh
#   - CAP_NET_BIND_SERVICE in devcontainer.json (binds port 443 without root)
#
# Start: caddy start --config infrastructure/local/Caddyfile --adapter caddyfile
# Reload: caddy reload --config infrastructure/local/Caddyfile --adapter caddyfile
# Stop:  caddy stop

{
	# Suppress Caddy's own HTTPS auto-provision — we use mkcert certs.
	auto_https off
	admin localhost:2019
}

# ── TLS snippet (mkcert wildcard cert) ───────────────────────────────────────
(tls_local) {
	tls {$HOME}/.local/share/mkcert/dev.cfxdevkit.org.pem \
	    {$HOME}/.local/share/mkcert/dev.cfxdevkit.org-key.pem
}

# ── Services available on VPS + locally ──────────────────────────────────────

# showcase-public (Next.js)  →  showcase.cfxdevkit.org on VPS
showcase.dev.cfxdevkit.org {
	import tls_local
	reverse_proxy localhost:3010
}

# docs-site  →  docs.cfxdevkit.org on VPS
# docs.dev.cfxdevkit.org {
# 	import tls_local
# 	reverse_proxy localhost:3012
# }

# MCP — high-level, user-facing services  →  mcp.cfxdevkit.org on VPS
# Split from devmcp: no overlap in tool surface (see ADR 0005).
# TODO: two separate MCP processes once surface is defined.
# MCP currently uses stdio transport. HTTP proxy requires mcphost or similar wrapper.
# See infrastructure/local/Caddyfile comment for activation steps.
mcp.dev.cfxdevkit.org {
	import tls_local
	reverse_proxy localhost:3020
}

# CAS automation suite  →  cas.cfxdevkit.org on VPS
# Port TBD — needs status review before enabling.
# cas.dev.cfxdevkit.org {
