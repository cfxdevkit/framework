# }

# ── Local-only services (never on VPS) ───────────────────────────────────────

# showcase-local (full devnode-backed showcase)
local.dev.cfxdevkit.org {
	import tls_local
	reverse_proxy localhost:3011
}

# devnode-server — Hono control-plane for the local Conflux node
devnode.dev.cfxdevkit.org {
	import tls_local
	reverse_proxy localhost:52000
}

# devmcp — MCP for low-level development actions (devnode, tooling, signing)
# Activate alongside mcp.dev.* — surfaces do not overlap.
devmcp.dev.cfxdevkit.org {
	import tls_local
	reverse_proxy localhost:3021
}
